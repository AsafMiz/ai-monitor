{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ai-monitor/web", "dev"],
      "port": 3000
    },
    {
      "name": "api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "src.main:app", "--reload", "--port", "8000"],
      "port": 8000
    }
  ]
}
